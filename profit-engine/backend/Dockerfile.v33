FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc \
    && rm -rf /var/lib/apt/lists/*

COPY requirements_live_v33.txt .
RUN pip install --no-cache-dir -r requirements_live_v33.txt

COPY live_monitor_v33.py \
     dashboard_server.py \
     dashboard.html \
     telegram_notif.py \
     ./

ENV PYTHONUNBUFFERED=1
EXPOSE 5001
